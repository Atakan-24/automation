      {
        "parameters": {
          "jsCode": "// Receive items from both Filter AND Read Existing Leads\n// Only process items that are actual new leads (have place_id + industry)\nconst allItems = $input.all();\nconst newLeads = allItems.filter(item =>\n  item.json && item.json.place_id && item.json.industry\n);\n\nif (newLeads.length === 0) return [];\n\nlet existingRows = [];\ntry {\n  existingRows = $('Read Existing Leads').all().map(i => i.json);\n} catch(e) { /* sheet empty or not yet run */ }\n\nconst result = [];\nfor (const leadItem of newLeads) {\n  const newLead = leadItem.json;\n  const alreadyContacted = existingRows.some(row =>\n    (row.phone && row.phone === newLead.phone) ||\n    (row.place_id && row.place_id === newLead.place_id)\n  );\n  if (!alreadyContacted) {\n    result.push({ json: newLead });\n  }\n}\n\nreturn result;"
        },
