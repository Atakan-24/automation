    {
      "parameters": {
        "jsCode": "// Read dynamic config from Google Sheets Config tab\n// Falls back to defaults if Config tab is empty\nconst configRows = $('Read Config').all().map(i => i.json);\nconst cfg = {};\nfor (const row of configRows) {\n  if (row.key && row.value) cfg[row.key] = row.value;\n}\n\nconst INDUSTRIES = cfg.target_industries\n  ? cfg.target_industries.split(',').map(s => s.trim())\n  : ['plumber', 'electrician', 'hvac contractor', 'roofer', 'painter'];\n\nconst CITIES = cfg.target_cities\n  ? cfg.target_cities.split(',').map(s => s.trim())\n  : ['Austin TX', 'Houston TX', 'Dallas TX', 'Phoenix AZ', 'Las Vegas NV'];\n\nconst LEADS_PER_RUN = parseInt(cfg.leads_per_run || '10');\n\nconst city = CITIES[Math.floor(Math.random() * CITIES.length)];\nconst industry = INDUSTRIES[Math.floor(Math.random() * INDUSTRIES.length)];\n\nreturn [{ json: { city, industry, leads_per_run: LEADS_PER_RUN, search_query: industry + ' in ' + city } }];"
      },
      "id": "node-config",
      "name": "Set Target City & Industry",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        380,
        400
      ]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "https://maps.googleapis.com/maps/api/place/textsearch/json",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "query",
              "value": "={{ $json.search_query }}"
            },
            {
              "name": "key",
              "value": "AIzaSyCndiGA-NcAxAu3zcyZSSiEUPkJRK4D91o"
