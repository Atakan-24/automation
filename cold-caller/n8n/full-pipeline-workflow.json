      "id": "node-place-details",
      "name": "Get Place Details (Rating + Reviews)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        1380,
        400
      ]
    },
    {
      "parameters": {
        "jsCode": "const lead = $('Skip If Already Called').item.json;\nconst details = $input.item.json.result || {};\n\n// Get phone from Place Details, normalize to 10 digits\nconst rawPhone = details.formatted_phone_number || lead.phone || '';\nconst phone = rawPhone.replace(/\\D/g, '').replace(/^1/, '');\n\n// Skip lead if no valid phone\nif (!phone || phone.length < 10) return [];\n\nconst rating = details.rating || lead.rating || 0;\nconst reviews_count = details.user_ratings_total || lead.reviews_count || 0;\nconst reviews = details.reviews || [];\nconst top_review = reviews.length > 0\n  ? reviews[0].text.substring(0, 120).replace(/\\n/g, ' ')\n  : '';\nconst is_open = details.opening_hours?.open_now;\nconst hours_note = is_open === true ? 'currently open' : is_open === false ? 'currently closed' : '';\n\nconst base = 'https://teamgoldllc.de/preview';\nconst params = new URLSearchParams({\n  name: lead.business_name,\n  type: lead.industry,\n  city: lead.city,\n  phone: phone\n});\nconst preview_url = base + '?' + params.toString();\n\nlet wa_message;\nif (reviews_count > 0) {\n  wa_message = `Hi ${lead.business_name}! This is Ryan from Team Gold.\\n\\nYou have ${reviews_count} reviews on Google with a ${rating}\u2b50 rating \u2014 clearly doing great work. But we noticed you don't have a website yet.\\n\\nWe put together a free website preview for ${lead.industry}s in ${lead.city}:\\n${preview_url}\\n\\nBook a free 30-min chat with our developer Atakan:\\nhttps://cal.com/atakanoztunc/30min`;\n} else {\n  wa_message = `Hi ${lead.business_name}! This is Ryan from Team Gold.\\n\\nWe noticed you don't have a website yet \u2014 you're missing out on customers searching for ${lead.industry}s in ${lead.city} on Google.\\n\\nWe put together a free website preview for you:\\n${preview_url}\\n\\nBook a free 30-min chat with our developer Atakan:\\nhttps://cal.com/atakanoztunc/30min`;\n}\n\nreturn [{ json: {\n  ...lead,\n  phone,\n  rating,\n  reviews_count,\n  top_review,\n  hours_note,\n  preview_url,\n  wa_message\n} }];"
      },
