        "jsCode": "let reply = '';\nlet actions = [];\ntry {\n  const resp = $input.first().json;\n  const content = resp.choices?.[0]?.message?.content || '{}';\n  const parsed = JSON.parse(content.trim());\n  reply = parsed.reply || 'Erledigt.';\n  actions = parsed.actions || [];\n} catch(e) {\n  reply = 'Ich habe deine Nachricht nicht ganz verstanden. Versuche: /status, /stop, /resume, /anrufe aus, /sms aus';\n}\n\n// Apply actions via toggle webhook (fire-and-forget approach — just build confirmation text)\nconst actionLabels = {\n  set_industry: (v) => 'Branche gesetzt auf: ' + v,\n  set_cities: (v) => 'Staedte gesetzt auf: ' + v.join(', '),\n  set_max_calls: (v) => 'Max Anrufe pro Tag: ' + v,\n  add_city: (v) => 'Stadt hinzugefuegt: ' + v,\n  remove_city: (v) => 'Stadt entfernt: ' + v,\n  set_paused: (v) => v ? 'Pipeline gestoppt' : 'Pipeline gestartet',\n};\n\nreturn [{ json: { tg_text: reply } }];"
