      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const ALLOWED_CHAT = '5381600986';\nconst upd = $input.first().json.body || $input.first().json;\nconst msg = upd.message || {};\nconst chatId = String((msg.chat || {}).id || '');\nconst text = (msg.text || '').trim().toLowerCase();\n\nif (chatId !== ALLOWED_CHAT) {\n  return [{ json: { action: 'ignore', chat_id: chatId } }];\n}\n\nconst TOGGLES = {\n  '/stop':'stop','stop':'stop',\n  '/resume':'resume','resume':'resume','/weiter':'resume','weiter':'resume',\n  '/anrufe aus':'calls_off','anrufe aus':'calls_off',\n  '/anrufe an':'calls_on','anrufe an':'calls_on',\n  '/sms aus':'sms_off','sms aus':'sms_off',\n  '/sms an':'sms_on','sms an':'sms_on',\n  '/preview aus':'preview_off','preview aus':'preview_off',\n  '/preview an':'preview_on','preview an':'preview_on',\n};\nconst TOGGLE_PAYLOADS = {\n  stop: {module:'paused',enabled:true},\n  resume: {module:'paused',enabled:false},\n  calls_off: {module:'calls',enabled:false},\n  calls_on: {module:'calls',enabled:true},\n  sms_off: {module:'sms',enabled:false},\n  sms_on: {module:'sms',enabled:true},\n  preview_off: {module:'preview',enabled:false},\n  preview_on: {module:'preview',enabled:true},\n};\nconst TOGGLE_MSGS = {\n  stop: 'GESTOPPT. Keine Anrufe mehr bis /resume.',\n  resume: 'AKTIV. Pipeline laeuft wieder normal.',\n  calls_off: 'Anrufe deaktiviert. SMS und Preview laufen weiter.',\n  calls_on: 'Anrufe wieder aktiviert.',\n  sms_off: 'SMS deaktiviert.',\n  sms_on: 'SMS wieder aktiviert.',\n  preview_off: 'Website-Preview deaktiviert.',\n  preview_on: 'Website-Preview wieder aktiviert.',\n};\n\nlet action = 'ai';\nif (text === '/start' || text === 'start' || text === '/run' || text === 'los') action = 'start';\nelse if (text === '/bericht' || text === 'bericht' || text === '/report' || text === 'report') action = 'report';\nelse if (text === '/demo' || text === 'demo' || text === 'testanruf') action = 'demo';\nelse if (text === '/status' || text === 'status') action = 'status';\nelse if (TOGGLES[text]) action = TOGGLES[text];\nelse if (text.startsWith('/')) action = 'help';\n\nconst togglePayload = TOGGLE_PAYLOADS[action] ? JSON.stringify(TOGGLE_PAYLOADS[action]) : '{}';\nconst toggleMsg = TOGGLE_MSGS[action] || '';\n\nreturn [{ json: { action, chat_id: chatId, text, toggle_payload: togglePayload, toggle_msg: toggleMsg } }];"
      },
