      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const ALLOWED_CHAT = '5381600986';\nconst upd = $input.first().json.body || $input.first().json;\nconst msg = upd.message || {};\nconst callback = upd.callback_query || null;\nconst chatId = String(\n  (msg.chat || {}).id ||\n  ((callback && callback.message && callback.message.chat) ? callback.message.chat.id : '') ||\n  ''\n);\nconst rawText = callback ? (callback.data || '') : (msg.text || '');\nconst text = rawText.trim().toLowerCase();\n\nif (chatId !== ALLOWED_CHAT) {\n  return [{ json: { action: 'ignore', chat_id: chatId, toggle_msg: '__IGNORE__' } }];\n}\n\nconst isCallback = !!callback;\nconst callbackQueryId = callback ? callback.id : null;\n\nconst TOGGLES = {\n  '/stop':'stop','stop':'stop',\n  '/resume':'resume','resume':'resume','/weiter':'resume','weiter':'resume',\n  '/anrufe aus':'calls_off','anrufe aus':'calls_off',\n  '/anrufe an':'calls_on','anrufe an':'calls_on',\n  '/sms aus':'sms_off','sms aus':'sms_off',\n  '/sms an':'sms_on','sms an':'sms_on',\n  '/preview aus':'preview_off','preview aus':'preview_off',\n  '/preview an':'preview_on','preview an':'preview_on',\n};\nconst TOGGLE_PAYLOADS = {\n  stop: {module:'paused',enabled:true},\n  resume: {module:'paused',enabled:false},\n  calls_off: {module:'calls',enabled:false},\n  calls_on: {module:'calls',enabled:true},\n  sms_off: {module:'sms',enabled:false},\n  sms_on: {module:'sms',enabled:true},\n  preview_off: {module:'preview',enabled:false},\n  preview_on: {module:'preview',enabled:true},\n};\nconst TOGGLE_MSGS = {\n  stop: 'GESTOPPT. Keine WhatsApp-Nachrichten mehr bis /resume.',\n  resume: 'AKTIV. WhatsApp-Outreach laeuft wieder.',\n  calls_off: 'Anrufe deaktiviert (Backup-System).',\n  calls_on: 'Anrufe wieder aktiviert.',\n  sms_off: 'SMS deaktiviert.',\n  sms_on: 'SMS wieder aktiviert.',\n  preview_off: 'Website-Preview deaktiviert.',\n  preview_on: 'Website-Preview wieder aktiviert.',\n  help: '__HELP__',\n  ignore: '__IGNORE__',\n};\n\nlet action = 'ai';\nlet waReplyPhone = null;\nlet waReplyText = null;\n\n// /r <phone> <message> — WhatsApp reply from Telegram\nif (text.startsWith('/r ') || text.startsWith('r ')) {\n  const parts = rawText.trim().split(' ');\n  parts.shift(); // remove /r\n  const maybePhone = (parts[0] || '').replace(/[^0-9]/g, '');\n  if (maybePhone.length >= 10) {\n    waReplyPhone = maybePhone;\n    waReplyText = parts.slice(1).join(' ');\n    action = 'wa_reply';\n  } else {\n    // /r without phone — reply to last sender\n    action = 'wa_reply_last';\n    waReplyText = parts.join(' ');\n  }\n} else if (text === '/start' || text === 'start' || text === '/run' || text === 'los') action = 'start';\nelse if (text === '/bericht' || text === 'bericht' || text === '/report' || text === 'report') action = 'report';\nelse if (text === '/demo' || text === 'demo' || text === 'testanruf') action = 'demo';\nelse if (text === '/status' || text === 'status') action = 'status';\nelse if (text === '/leads' || text === 'leads') action = 'leads';\nelse if (text === '/einstellungen' || text === 'einstellungen' || text === '/settings') action = 'einstellungen';\nelse if (text === '/help' || text === '/hilfe' || text === 'help' || text === 'hilfe') action = 'help';\nelse if (TOGGLES[text]) action = TOGGLES[text];\nelse if (text.startsWith('/')) action = 'help';\n\nconst togglePayload = TOGGLE_PAYLOADS[action] || null;\nconst toggleMsg = TOGGLE_MSGS[action] || null;\n\nreturn [{ json: {\n  action,\n  chat_id: chatId,\n  text: rawText,\n  toggle_payload: togglePayload ? JSON.stringify(togglePayload) : null,\n  toggle_msg: toggleMsg,\n  is_callback: isCallback,\n  callback_query_id: callbackQueryId,\n  wa_reply_phone: waReplyPhone,\n  wa_reply_text: waReplyText,\n} }];"
      },
